# ═══════════════════════════════════════════════
# Resource Intelligence AI — Environment Config
# ═══════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=resource_intelligence
DB_USER=postgres
DB_PASSWORD=postgres

# ── LLM Provider ────────────────────────────────
# Options: anthropic | openai | ollama | lmstudio
LLM_PROVIDER=anthropic

# Anthropic (Cloud)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (Cloud — alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Ollama (Local Mac) — brew install ollama && ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LM Studio (Local Mac) — download from lmstudio.ai
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

# ── Matching Engine Weights ──────────────────────
WEIGHT_SKILL=0.40
WEIGHT_EXP=0.25
WEIGHT_AVAIL=0.20
WEIGHT_ALLOC=0.15
